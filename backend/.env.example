# Environment: development, staging, production
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Database Configuration
DATABASE_URL=postgresql+asyncpg://sourcelens:sourcelens@localhost:5432/sourcelens_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=384

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral

# Indexing Configuration
INDEXING_MAX_WORKERS=4
INDEXING_TIMEOUT_SECONDS=3600
INDEXING_BATCH_SIZE=100
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# Retrieval Configuration
RETRIEVAL_TOP_K=10
RETRIEVAL_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_RERANK_TOP_K=5

# File System Configuration
TEMP_DIR=/tmp/sourcelens
REPO_STORAGE_DIR=/var/sourcelens/repos

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Sentry Configuration (optional)
SENTRY_DSN=

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
