# SourceLens Environment Configuration
# Copy this file to .env and fill in the actual values

# Database Configuration
DATABASE_URL=postgresql://sourcelens:sourcelens_dev@localhost:5432/sourcelens_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Vector Database (pgvector)
VECTOR_DATABASE_URL=postgresql://sourcelens:sourcelens_dev@localhost:5432/sourcelens_db

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=your_github_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret_here
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT Configuration
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# Backend API
BACKEND_HOST=localhost
BACKEND_PORT=8000
BACKEND_DEBUG=true
BACKEND_LOG_LEVEL=INFO

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Embeddings
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
EMBEDDINGS_DIMENSION=384
EMBEDDINGS_BATCH_SIZE=32

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.7

# Indexing Configuration
INDEXING_BATCH_SIZE=10
INDEXING_MAX_WORKERS=4
INDEXING_TIMEOUT_SECONDS=300
INDEXING_SKIP_PATTERNS=node_modules,__pycache__,.git,.next,dist,build,coverage

# Retrieval Configuration
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_ENABLE_KEYWORD_SEARCH=true
RETRIEVAL_ENABLE_RERANKING=true

# Repository Configuration
REPOSITORY_CLONE_DIR=/tmp/sourcelens_repos
REPOSITORY_MAX_SIZE_MB=1000
REPOSITORY_LANGUAGES=python,typescript,javascript,go,rust,java,markdown,json,yaml,toml

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/sourcelens.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Worker Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
WORKER_CONCURRENCY=4

# Sentry (optional, for error tracking)
SENTRY_DSN=

# Feature Flags
FEATURE_ENABLE_HYBRID_RETRIEVAL=false
FEATURE_ENABLE_CODE_EDITING=false
FEATURE_ENABLE_PR_ANALYSIS=false
